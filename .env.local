# Proxy target for Next.js (server-side rewrites + /api/auth/* route handlers)
API_PROXY_TARGET=http://127.0.0.1:8000

# Browser API base — leave commented to use same-origin /api/* proxy (recommended).
# Uncomment only if you want the browser to call the API directly (CORS must allow your frontend origin).
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
