# Copy to .env before: docker compose up --build -d
# Replace YOUR_SERVER_IP with the machine's LAN IP or hostname (e.g. 192.168.1.50)

SECRET_KEY=replace-with-openssl-rand-hex-32
POSTGRES_PASSWORD=choose-a-strong-password

# Frontend URL(s) allowed by the API (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://YOUR_SERVER_IP:3000

# Optional: only if browsers call the API directly on port 8000 (default: use Next proxy on :3000)
# NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8000
